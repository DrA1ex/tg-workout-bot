{
  "name": "training-bot",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "web": "node src/web.js",
    "build:web": "node scripts/build-web.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "migrate": "node src/db/migrate-cli.js",
    "test:web:e2e": "npm run build:web && playwright test",
    "test:web:e2e:headed": "npm run build:web && playwright test --headed",
    "test:web:e2e:ui": "npm run build:web && playwright test --ui",
    "test:web:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "dotenv": "^17.2.1",
    "dottie": "file:vendor/dottie",
    "jszip": "^3.10.1",
    "quickchart-js": "^3.1.0",
    "sequelize": "6.37.8",
    "sqlite3": "6.0.1",
    "telegraf": "^4.12.2"
  },
  "devDependencies": {
    "@jest/globals": "30.4.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "esbuild": "^0.25.5",
    "jest": "30.4.1",
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "glob": "13.0.6",
    "test-exclude": "8.0.0",
    "lodash": "4.18.1",
    "tar-fs": "2.1.5",
    "uuid": "11.1.1",
    "validator": "13.15.35"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true,
    "sqlite3@6.0.1": true,
    "unrs-resolver@1.12.2": true
  }
}
